---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Solid Dosage Forms — Onyx Corporation">

  <style is:global>
    :root { --navy: #1B2A6B; --navy-dark: #111d4e; --navy-light: #2a3d8f; --accent: #4a90d9; }
    .page-hero { background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-light) 100%); position: relative; overflow: hidden; padding: 140px 0 80px; }
    .page-hero::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px; }
    .section-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); }
    .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.5); font-size: 0.8rem; text-decoration: none; transition: color 0.2s; margin-bottom: 1.5rem; }
    .back-link:hover { color: white; }
    .product-card { background: #dde2e8; border: 1px solid #c8d0da; border-radius: 16px; overflow: hidden; transition: all 0.35s ease; position: relative; }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px rgba(27,42,107,0.15); border-color: var(--navy); }
    .product-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--accent)); transform: scaleX(0); transform-origin: left; transition: transform 0.35s ease; }
    .product-card:hover::before { transform: scaleX(1); }
    .product-image-placeholder { width: 100%; height: 200px; display: flex; align-items: center; justify-content: center; }
  </style>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <a href="/#products" class="back-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
        <span x-text="t('All Categories', 'Все категории')"></span>
      </a>
      <p class="section-label mb-4" x-text="t('Product Catalogue', 'Каталог продуктов')"></p>
      <h1 class="text-5xl md:text-6xl font-light text-slate-100 serif mb-4" x-text="t('Solid Dosage Forms', 'Твёрдые лекарственные формы')"></h1>
      <p class="text-slate-100/50 font-light max-w-xl" x-text="t('Tablets, capsules and powders manufactured under strict GMP conditions.', 'Таблетки, капсулы и порошки, произведённые в строгих условиях GMP.')"></p>
    </div>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <!-- Prostazolin / Простазолин -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f0fe">
            <img src="/medicines/Простазолин.jpg" alt="Простазолин"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Prostazolin', 'Простазолин')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Tamsulosin HCl 0.4mg + Dutasteride 0.5mg', 'Тамсулозина гидрохлорид 0,4мг + Дутастерид 0,5мг')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Combined alpha-blocker and 5-alpha-reductase inhibitor capsules for benign prostatic hyperplasia. 30 capsules.', 'Комбинированные капсулы альфа-блокатора и ингибитора 5-альфа-редуктазы при доброкачественной гиперплазии предстательной железы. 30 капсул.')"></p>
          </div>
        </div>

        <!-- Tilorsin / Тилорсин -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fef3e2">
            <img src="/medicines/Тилорсин.jpg" alt="Тилорсин"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Tilorsin', 'Тилорсин')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Tilorone 125mg', 'Тилорон 125мг')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Antiviral and immunomodulatory capsules for treatment and prevention of influenza and other viral infections. 10 capsules.', 'Противовирусные и иммуномодулирующие капсулы для лечения и профилактики гриппа и других вирусных инфекций. 10 капсул.')"></p>
          </div>
        </div>

        <!-- Betropil / Бетропил -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f0fe">
            <img src="/medicines/Бетропил.jpg" alt="Бетропил"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Betropil', 'Бетропил')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Capsules for oral use', 'Капсулы для приёма внутрь')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Nootropic and neuroprotective capsules supporting cerebral circulation and cognitive function. 20 capsules.', 'Ноотропные и нейропротекторные капсулы для поддержки мозгового кровообращения и когнитивных функций. 20 капсул.')"></p>
          </div>
        </div>

        <!-- Bionefron / Бионефрон -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f8f0">
            <img src="/medicines/Бионефрон.jpg" alt="Бионефрон"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Bionefron', 'Бионефрон')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Centaury + Rosemary + Lovage root', 'Золототысячник + Розмарин + Корень любистка')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Herbal capsules with centaury herb, rosemary officinalis and lovage root for urinary tract support. 60 capsules.', 'Растительные капсулы с золототысячником, розмарином и корнем любистка для поддержки мочевыводящих путей. 60 капсул.')"></p>
          </div>
        </div>

        <!-- Duobrain / Дуобрейн -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f0fe">
            <img src="/medicines/Дуобрейн.jpg" alt="Дуобрейн"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Duobrain', 'Дуобрейн')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meldonium 250mg + Ethylmethylhydroxypyridine succinate 250mg', 'Мелдоний 250мг + Этилметилгидроксипиридина сукцинат 250мг')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Combined neuroprotective and antioxidant capsules for cerebrovascular disorders and cognitive support. 20 capsules.', 'Комбинированные нейропротекторные и антиоксидантные капсулы при цереброваскулярных расстройствах. 20 капсул.')"></p>
          </div>
        </div>

        <!-- Mildargin / Милдаргин -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #f0e8fe">
            <img src="/medicines/Милдаргин.jpg" alt="Милдаргин"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Mildargin', 'Милдаргин')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meldonium + Arginine hydrochloride', 'Мелдоний + Аргинина гидрохлорид')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Combined cardioprotective capsules with meldonium and arginine for cardiovascular and metabolic support. 20 capsules.', 'Комбинированные кардиопротекторные капсулы с мелдонием и аргинином для сердечно-сосудистой и метаболической поддержки. 20 капсул.')"></p>
          </div>
        </div>

        <!-- Mildrocard / Милдрокард -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fef3e2">
            <img src="/medicines/Милдрокард.jpg" alt="Милдрокард"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Mildrocard', 'Милдрокард')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meldonium 250mg', 'Мелдоний 250мг')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Cardioprotective capsules with meldonium for ischemic heart disease, chronic heart failure and reduced exercise tolerance. 40 capsules.', 'Кардиопротекторные капсулы с мелдонием при ишемической болезни сердца, хронической сердечной недостаточности и сниженной толерантности к нагрузкам. 40 капсул.')"></p>
          </div>
        </div>

        <!-- Nucleodin / Нуклеодин -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fce8e8">
            <img src="/medicines/Нуклеодин.jpg" alt="Нуклеодин"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Nucleodin', 'Нуклеодин')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Riboflavin-5-phosphate + Uridine-5-phosphate complex', 'Рибофлавин-5-фосфат + Уридин-5-фосфат комплекс')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Neuroprotective capsules with nucleotide complex supporting nerve cell regeneration and peripheral neuropathy treatment. 30 capsules.', 'Нейропротекторные капсулы с нуклеотидным комплексом для поддержки регенерации нервных клеток и лечения периферической нейропатии. 30 капсул.')"></p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
