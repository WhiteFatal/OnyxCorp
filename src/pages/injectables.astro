---
import ProductCard from '../components/product-card.astro'
import ProductsHero from '../components/products-hero.astro'
import Layout from '../layouts/Layout.astro'
import { getProductsByCategory, imageUrl } from '../lib/sanity.js'

const products = await getProductsByCategory('injectables')
---

<Layout title="Injectable Solutions — Onyx Corporation">

  <!-- PAGE HERO -->
  <ProductsHero />

  <!-- PRODUCTS GRID -->
  <ProductCard products={products} imageUrl={imageUrl} /> 

</Layout>
