---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Injectable Solutions — Onyx Corporation">

  <style is:global>
    :root { --navy: #1B2A6B; --navy-dark: #111d4e; --navy-light: #2a3d8f; --accent: #4a90d9; }
    .page-hero { background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-light) 100%); position: relative; overflow: hidden; padding: 140px 0 80px; }
    .page-hero::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px; }
    .section-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); }
    .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.5); font-size: 0.8rem; text-decoration: none; transition: color 0.2s; margin-bottom: 1.5rem; }
    .back-link:hover { color: white; }
    .product-card { background: #dde2e8; border: 1px solid #c8d0da; border-radius: 16px; overflow: hidden; transition: all 0.35s ease; position: relative; }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px rgba(27,42,107,0.15); border-color: var(--navy); }
    .product-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--accent)); transform: scaleX(0); transform-origin: left; transition: transform 0.35s ease; }
    .product-card:hover::before { transform: scaleX(1); }
    .product-image-placeholder { width: 100%; height: 200px; display: flex; align-items: center; justify-content: center; }
  </style>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <a href="/#products" class="back-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
        <span x-text="t('All Categories', 'Все категории')"></span>
      </a>
      <p class="section-label mb-4" x-text="t('Product Catalogue', 'Каталог продуктов')"></p>
      <h1 class="text-5xl md:text-6xl font-light text-slate-100 serif mb-4" x-text="t('Injectable Solutions', 'Инъекционные растворы')"></h1>
      <p class="text-slate-100/50 font-light max-w-xl" x-text="t('Sterile vials and ampoules for hospital and clinical use.', 'Стерильные флаконы и ампулы для больниц и клиник.')"></p>
    </div>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <!-- Batferon / Батферон -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #f0e8fe">
            <img src="/medicines/Батферон.jpg" alt="Батферон"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Batferon', 'Батферон')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meglumine Acridonacetate 250mg/2ml', 'Меглумина акридонацетат 250мг/2мл')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Antiviral and immunomodulatory solution in 5 ampoules of 2ml for IV/IM injection.', 'Противовирусный и иммуномодулирующий раствор, 5 ампул по 2 мл для в/в и в/м введения.')"></p>
          </div>
        </div>

        <!-- Bioflex-Dual / Биофлекс-Дуал -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #f0e8fe">
            <img src="/medicines/Биофлекс-Дуал.jpg" alt="Биофлекс-Дуал"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Bioflex-Dual', 'Биофлекс-Дуал')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Dual-Ampoule Solution', 'Раствор в двойных ампулах')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Anti-inflammatory, analgesic and anticonvulsant dual-ampoule solution: 3 ampoules A (2ml) + 3 ampoules B (1ml) for IM injection.', 'Противовоспалительное, анальгетическое и противосудорожное средство: 3 ампулы А (2мл) + 3 ампулы Б (1мл) для в/м введения.')"></p>
          </div>
        </div>

        <!-- Blockavit B-12 / Блокавит Б-12 -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f0fe">
            <img src="/medicines/Блокавит Б-12.jpg" alt="Блокавит Б-12"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Blockavit B-12', 'Блокавит Б-12')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Betamethasone + Diclofenac + Vitamin B12 / 3ml', 'Бетаметазон + Диклофенак + Витамин B12 / 3мл')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Combined corticosteroid, NSAID and vitamin B12 solution. 6 ampoules of 3ml for IM injection.', 'Комбинированный раствор кортикостероида, НПВП и витамина B12. 6 ампул по 3 мл для в/м введения.')"></p>
          </div>
        </div>

        <!-- Dicortan / Дикортан -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fef3e2">
            <img src="/medicines/Дикортан.jpg" alt="Дикортан"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Dicortan', 'Дикортан')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Betamethasone + Diclofenac + Vitamin B12 / 3ml', 'Бетаметазон + Диклофенак + Витамин B12 / 3мл')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Combined corticosteroid, NSAID and vitamin B12 solution. 3 ampoules of 3ml for IM injection, sterile.', 'Комбинированный раствор кортикостероида, НПВП и витамина B12. 3 ампулы по 3 мл для в/м введения, стерильный.')"></p>
          </div>
        </div>

        <!-- Lambene / Ламбене -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f8f0">
            <img src="/medicines/Ламбене.jpg" alt="Ламбене"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Lambene', 'Ламбене')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Double Ampoules', 'Двойные ампулы')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Anti-inflammatory, analgesic and anticonvulsant dual-ampoule solution: 3 ampoules A (2ml) + 3 ampoules B (1ml) for IM injection, sterile.', 'Противовоспалительное, анальгетическое и противосудорожное средство: 3 ампулы А (2мл) + 3 ампулы Б (1мл) для в/м введения, стерильный.')"></p>
          </div>
        </div>

        <!-- Maxiferon / Максиферон -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fce8e8">
            <img src="/medicines/Максиферон.jpg" alt="Максиферон"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Maxiferon', 'Максиферон')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meglumine Acridonacetate 12.5% / 2ml', 'Меглумина акридонацетат 12,5% / 2мл')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Antiviral and immunomodulatory 12.5% solution. 5 ampoules of 2ml for IV/IM injection, sterile and apyrogenic.', 'Противовирусный и иммуномодулирующий раствор 12,5%. 5 ампул по 2 мл для в/в и в/м введения, стерильный, апирогенный.')"></p>
          </div>
        </div>

        <!-- Speyferon / Спейферон -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #e8f8f0">
            <img src="/medicines/Спейферон.jpg" alt="Спейферон"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Speyferon', 'Спейферон')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meglumine Acridonacetate 12.5% / 2ml', 'Меглумина акридонацетат 12,5% / 2мл')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Antiviral and immunomodulatory 12.5% solution. 5 ampoules of 2ml for IV/IM injection, sterile.', 'Противовирусный и иммуномодулирующий раствор 12,5%. 5 ампул по 2 мл для в/в и в/м введения, стерильный.')"></p>
          </div>
        </div>

        <!-- Ticiron / Тицирон -->
        <div class="product-card">
          <div class="product-image-placeholder" style="background: #fff8e1">
            <img src="/medicines/Тицирон.jpg" alt="Тицирон"/>
          </div>
          <div class="p-5">
            <h2 class="text-xl serif font-bold mb-1" style="color: var(--navy-dark)" x-text="t('Ticiron', 'Тицирон')"></h2>
            <h3 class="text-sm serif font-semibold mb-2" style="color: var(--accent)" x-text="t('Meglumine Acridonacetate (Neovir)', 'Меглумина акридонацетат (Неовир)')"></h3>
            <p class="text-gray-700 text-sm font-light leading-relaxed" x-text="t('Antiviral and immunomodulatory injectable solution. Sterile ampoules for IV/IM use.', 'Противовирусный и иммуномодулирующий инъекционный раствор. Стерильные ампулы для в/в и в/м введения.')"></p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
