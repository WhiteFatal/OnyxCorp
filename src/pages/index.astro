---
import Layout from '../layouts/Layout.astro'
import CategoryCard from '../components/category-card.astro';
---

<Layout title="Onyx Corporation — Pharmaceutical Manufacturing">

  <!-- HERO -->
  <section class="hero flex items-center">
    <div class="hero-grid"></div>
    <div class="hero-orb"></div>

    <div class="max-w-7xl mx-auto px-6 pt-18 pb-16 relative z-10 w-full">
      <div class="max-w-2xl">

        <p class="fade-up text-[0.7rem] font-medium tracking-[0.25em] uppercase text-accent mb-6"
           x-text="t('Pharmaceutical Manufacturing', 'Фармацевтическое производство')"></p>

        <h1 class="fade-up delay-1 text-5xl md:text-6xl lg:text-7xl font-light text-slate-100 font-serif leading-20 mb-6">
          <span x-text="t('Advancing', 'Качество')"></span><br>
          <span class="font-semibold" x-text="t('Healthcare', 'на каждом')"></span><br>
          <span class="text-silver" x-text="t('Worldwide', 'этапе')"></span>
        </h1>

        <p class="fade-up delay-2 text-slate-100/60 text-lg font-light leading-relaxed mb-10 max-w-11/12"
           x-text="t(
             'Onyx Corporation delivers certified pharmaceutical products to hospitals, clinics, and pharmacy chains across the region. Quality, reliability, and compliance — at every step.',
             'Onyx Corporation поставляет сертифицированные фармацевтические продукты больницам, клиникам и аптечным сетям по всему региону. Качество, надёжность и соответствие стандартам — на каждом этапе.'
           )">
        </p>

        <div class="fade-up delay-3 flex flex-wrap gap-4">
          <a href="#products"
             class="bg-gradient-to-br from-accent to-blue-600 text-white py-[0.9rem] px-10 rounded-lg font-medium text-[0.9rem] tracking-[0.05em] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,144,217,0.4)] no-underline"
             x-text="t('Explore Products', 'Каталог продуктов')"></a>
          <a href="#contact"
             class="border border-white/30 text-white py-[0.9rem] px-10 rounded-lg font-normal text-[0.9rem] tracking-[0.05em] bg-transparent transition-all duration-300 hover:bg-white/[0.08] hover:border-white/50 no-underline"
             x-text="t('Partner With Us', 'Стать партнёром')"></a>
        </div>

        <div class="fade-up delay-4 grid grid-cols-3 gap-4 mt-16">
          <div class="border border-white/10 bg-white/[0.04] backdrop-blur-[8px] transition-all duration-300 hover:bg-white/[0.08] hover:border-white/20 hover:-translate-y-0.5 rounded-xl p-5">
            <div class="text-3xl font-light text-slate-100 font-serif mb-1">200+</div>
            <div class="text-xs text-slate-100/40 font-light" x-text="t('Products in Portfolio', 'Продуктов в портфеле')"></div>
          </div>
          <div class="border border-white/10 bg-white/[0.04] backdrop-blur-[8px] transition-all duration-300 hover:bg-white/[0.08] hover:border-white/20 hover:-translate-y-0.5 rounded-xl p-5">
            <div class="text-3xl font-light text-slate-100 font-serif mb-1">15+</div>
            <div class="text-xs text-slate-100/40 font-light" x-text="t('Years of Experience', 'Лет опыта')"></div>
          </div>
          <div class="border border-white/10 bg-white/[0.04] backdrop-blur-[8px] transition-all duration-300 hover:bg-white/[0.08] hover:border-white/20 hover:-translate-y-0.5 rounded-xl p-5">
            <div class="text-3xl font-light text-slate-100 font-serif mb-1">GMP</div>
            <div class="text-xs text-slate-100/40 font-light" x-text="t('Certified Facilities', 'Сертифицировано')"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="py-18 bg-[#e8ecf0]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <p class="text-[0.7rem] font-medium tracking-[0.25em] uppercase text-accent mb-4"
           x-text="t('Our Portfolio', 'Наш портфель')"></p>
        <h2 class="text-4xl md:text-5xl font-light font-serif text-navy mb-4"
            x-text="t('Product Categories', 'Категории продуктов')"></h2>
        <p class="text-gray-700 font-light max-w-xl"
           x-text="t('A comprehensive range of pharmaceutical products manufactured to the highest international standards.',
           'Широкий спектр фармацевтических продуктов, произведённых по высшим международным стандартам.')">
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Solid Dosage -->
        <CategoryCard 
          category="solid-dosage"
          icon="1"
          name="t('Solid Dosage Forms', 'Твёрдые лекарственные формы')"
          description="t('Tablets, capsules, powders and coated dosage forms produced under strict GMP conditions.',
             'Таблетки, капсулы, порошки и покрытые оболочкой формы, произведённые в строгих условиях GMP.')"
        /> 
        <!-- Injectables -->
        <CategoryCard 
          category="injectables"
          icon="2"
          name="t('Injectable Solutions', 'Инъекционные растворы')"
          description="t('Sterile vials and ampoules for hospital and clinical use, meeting international pharmacopoeial standards.',
              'Стерильные флаконы и ампулы для больниц и клиник, соответствующие международным стандартам.')"
        />
        <!-- Antibiotics -->
         <CategoryCard 
          category="antibiotics"
          icon="3"
          name="t('Antibiotics', 'Антибиотики')"
          description="t('Broad and narrow-spectrum antibiotics for bacterial infections, available in multiple dosage forms.',
             'Антибиотики широкого и узкого спектра для лечения бактериальных инфекций в различных формах.')"
        />
        <!-- Liquids & Externals -->
         <CategoryCard 
          category="liquids-externals"
          icon="4"
          name="t('Liquids & Externals', 'Жидкости и внешние препараты')"
          description="t('Syrups, Suspensions, Eye/Ear/Nose Drops, Sprays, and Ointments.',
             'Сиропы, суспензии, капли для глаз/уха/носа, спреи и мази.')"
        />
        <!-- OTC -->
        <CategoryCard 
          category="otc"
          icon="5"
          name="t('OTC & Consumer Health', 'OTC препараты')"
          description="t('Over-the-counter products for pharmacy chains — vitamins, analgesics, and wellness supplements.',
             'Безрецептурные препараты для аптечных сетей — витамины, анальгетики и добавки.')"
        />
        <!-- CTA card -->
        <div class="rounded-2xl p-8 flex flex-col justify-between bg-gradient-to-br from-navy to-navy-light">
          <div>
            <p class="text-slate-100/50 text-xs uppercase tracking-widest mb-4"
               x-text="t('Partnership', 'Партнёрство')"></p>
            <h3 class="text-xl font-serif font-semibold text-slate-100 mb-3"
                x-text="t('Looking for a reliable supplier?', 'Ищете надёжного поставщика?')"></h3>
            <p class="text-slate-100/60 text-sm font-light leading-relaxed"
               x-text="t(`We work with hospitals, clinic networks, and pharmacy distributors. Let's discuss your needs.`,
               `Мы работаем с больницами, клиническими сетями и дистрибьюторами.`)">
            </p>
          </div>
          <a href="#contact"
             class="mt-8 inline-block text-center border border-white/30 text-white py-[0.9rem] px-10 rounded-lg font-normal text-sm tracking-[0.05em] bg-transparent transition-all duration-300 hover:bg-white/[0.08] hover:border-white/50 no-underline"
             x-text="t('Contact Our Team', 'Связаться с нами')"></a>
        </div>

      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about-section py-18">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

        <div>
          <p class="text-[0.7rem] font-medium tracking-[0.25em] uppercase text-accent mb-4"
             x-text="t('About Onyx', 'Об Onyx')"></p>
          <h2 class="text-4xl md:text-5xl font-light font-serif text-navy mb-6"
              x-text="t('Built on Science. Driven by Purpose.', 'Основано на науке. Движимо целью.')"></h2>
          <p class="text-gray-700 font-light leading-relaxed mb-6"
             x-text="t('Onyx Corporation is a pharmaceutical manufacturing company dedicated to producing high-quality medicines for healthcare providers across the region. With over 15 years in the industry, we combine scientific rigor with operational excellence.',
             'Onyx Corporation — фармацевтическая производственная компания, стремящаяся производить высококачественные лекарства для медицинских учреждений региона. Более 15 лет опыта в отрасли.')">
          </p>
          <p class="text-gray-700 font-light leading-relaxed mb-10"
             x-text="t('Our facilities are GMP-certified and our processes comply with international pharmacopoeial standards, ensuring every product meets the highest expectations of safety and efficacy.',
             'Наши производственные мощности сертифицированы по GMP, а процессы соответствуют международным фармакопейным стандартам.')">
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="border-l-2 border-navy pl-5">
              <h4 class="font-medium text-sm mb-1 text-navy" x-text="t('Quality Assurance', 'Гарантия качества')"></h4>
              <p class="text-gray-600 text-sm font-light" x-text="t('Rigorous testing at every production stage.', 'Строгий контроль на каждом этапе.')"></p>
            </div>
            <div class="border-l-2 border-navy pl-5">
              <h4 class="font-medium text-sm mb-1 text-navy" x-text="t('Regulatory Compliance', 'Соответствие нормам')"></h4>
              <p class="text-gray-600 text-sm font-light" x-text="t('Fully registered and compliant with local authorities.', 'Полное соответствие требованиям регуляторов.')"></p>
            </div>
            <div class="border-l-2 border-navy pl-5">
              <h4 class="font-medium text-sm mb-1 text-navy" x-text="t('Reliable Supply Chain', 'Надёжные поставки')"></h4>
              <p class="text-gray-600 text-sm font-light" x-text="t('On-time delivery to pharmacies and hospitals.', 'Своевременные поставки в аптеки и больницы.')"></p>
            </div>
            <div class="border-l-2 border-navy pl-5">
              <h4 class="font-medium text-sm mb-1 text-navy" x-text="t('Expert Support', 'Экспертная поддержка')"></h4>
              <p class="text-gray-600 text-sm font-light" x-text="t('Dedicated account managers and medical liaisons.', 'Персональные менеджеры и медицинские представители.')"></p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="rounded-3xl p-10 relative overflow-hidden bg-gradient-to-br from-navy-dark to-navy-light">
            <!-- Dot pattern — must stay inline, Tailwind cannot express positioned radial gradients -->
            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 70%, white 1px, transparent 1px); background-size: 24px 24px;"></div>
            <div class="relative z-10 grid grid-cols-2 gap-6">
              <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <div class="text-4xl font-serif font-light text-slate-100 mb-2">200+</div>
                <div class="text-slate-100/50 text-xs uppercase tracking-wider" x-text="t('SKUs Available', 'Позиций в наличии')"></div>
              </div>
              <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <div class="text-4xl font-serif font-light text-slate-100 mb-2">15+</div>
                <div class="text-slate-100/50 text-xs uppercase tracking-wider" x-text="t('Years Active', 'Лет на рынке')"></div>
              </div>
              <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <div class="text-4xl font-serif font-light text-slate-100 mb-2">50+</div>
                <div class="text-slate-100/50 text-xs uppercase tracking-wider" x-text="t('Partner Hospitals', 'Больниц-партнёров')"></div>
              </div>
              <div class="bg-white/10 rounded-2xl p-6 backdrop-blur-sm">
                <div class="text-4xl font-serif font-light text-slate-100 mb-2">GMP</div>
                <div class="text-slate-100/50 text-xs uppercase tracking-wider" x-text="t('Certified', 'Сертифицировано')"></div>
              </div>
            </div>
            <div class="relative z-10 mt-6 bg-white/5 rounded-2xl p-6 border border-white/10">
              <p class="text-slate-100/70 text-sm font-light italic leading-relaxed font-serif"
                 x-text="t('Our mission is to make quality pharmaceutical products accessible to every healthcare provider, every time.',
                 'Наша цель — сделать качественные фармацевтические продукты доступными для каждого медицинского учреждения.')">
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact-section py-18">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid grid-cols-1 gap-20">
        <div>
          <p class="text-[0.7rem] font-medium tracking-[0.25em] uppercase text-accent mb-4"
             x-text="t('Get In Touch', 'Связаться')"></p>
          <h2 class="text-4xl md:text-5xl font-light font-serif text-slate-100 mb-6"
              x-text="t('Partner With Onyx', 'Станьте партнёром Onyx')"></h2>
          <p class="text-slate-100/50 font-light leading-relaxed mb-10"
             x-text="t(`Whether you represent a hospital procurement team, pharmacy chain, or distribution network — we'd like to hear from you.`,
             `Представляете ли вы отдел закупок больницы, аптечную сеть или дистрибьюторскую сеть — мы готовы вас выслушать.`)">
          </p>

          <div class="flex flex-wrap gap-12 mt-10">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-slate-100/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-slate-100/30 text-xs uppercase tracking-wider mb-1" x-text="t('Email', 'Эл. почта')"></p>
                <p class="text-slate-100/80 text-sm">info@onyxcorporation.com</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-slate-100/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-slate-100/30 text-xs uppercase tracking-wider mb-1" x-text="t('Phone', 'Телефон')"></p>
                <p class="text-slate-100/80 text-sm">+995 32 256 09 09</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-slate-100/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-slate-100/30 text-xs uppercase tracking-wider mb-1" x-text="t('Address', 'Адрес')"></p>
                <p class="text-slate-100/80 text-sm" x-text="t('6 Giorgi Saakadze Descent, Georgia', 'Спуск Георгия Саакадзе 6, Тбилиси, Грузия')"></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>