---
import '../styles/global.css'

const { title = 'Onyx Corporation' } = Astro.props
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/Onyx_favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body
    x-data="{ lang: localStorage.getItem('lang') || 'en', mobileOpen: false, t(en, ru) { return this.lang === 'en' ? en : ru } }"
    class="bg-[#e8ecf0] text-navy-dark overflow-x-hidden font-sans"
  >

    <!-- NAVBAR -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-navy/97 backdrop-blur-md border-b border-white/10">
      <div class="max-w-7xl mx-auto px-6 py-2 flex items-center justify-between">

        <!-- Logo -->
        <a href="/">
          <img
            src="/images/Onyx_Transparent.png"
            alt="Onyx Corporation"
            class="h-24 w-auto"
            style="mix-blend-mode: screen;"
          />
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-16">
          <a href="/#products" class="text-sm font-normal tracking-widest uppercase text-slate-100/80 hover:text-slate-100 transition-colors" x-text="t('Products', 'Продукты')"></a>
          <a href="/#about" class="text-sm font-normal tracking-widest uppercase text-slate-100/80 hover:text-slate-100 transition-colors" x-text="t('About Us', 'О нас')"></a>
          <a href="/#contact" class="text-sm font-normal tracking-widest uppercase text-slate-100/80 hover:text-slate-100 transition-colors" x-text="t('Contact', 'Контакты')"></a>
        </div>

        <!-- Right side -->
        <div class="flex items-center gap-3">

          <!-- Language switcher -->
          <div class="flex items-center gap-1 border border-white/10 rounded-md p-0.5">
            <button
              class="text-xs font-medium tracking-widest px-2.5 py-1 rounded cursor-pointer transition-all duration-200"
              :class="lang === 'en' ? 'text-white bg-white/10' : 'text-white/50'"
              @click="lang = 'en'; localStorage.setItem('lang', 'en')"
            >EN</button>
            <button
              class="text-xs font-medium tracking-widest px-2.5 py-1 rounded cursor-pointer transition-all duration-200"
              :class="lang === 'ru' ? 'text-white bg-white/10' : 'text-white/50'"
              @click="lang = 'ru'; localStorage.setItem('lang', 'ru')"
            >RU</button>
          </div>

          <!-- CTA button -->
          <a
            href="/#contact"
            class="hidden md:inline-block text-sm font-normal tracking-widest uppercase text-white py-2 px-5 rounded-lg bg-gradient-to-br from-accent to-blue-600 transition-all duration-300 hover:-translate-y-0.5"
            x-text="t('Get in Touch', 'Связаться')"
          ></a>

          <!-- Mobile hamburger -->
          <button class="md:hidden text-slate-100/70 hover:text-slate-100" @click="mobileOpen = !mobileOpen">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path x-show="!mobileOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
              <path x-show="mobileOpen" x-cloak stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div x-show="mobileOpen" x-cloak x-transition class="md:hidden border-t border-white/10 px-6 py-4 flex flex-col gap-4">
        <a href="/#products" @click="mobileOpen=false" class="text-sm text-slate-100/70 hover:text-slate-100" x-text="t('Products', 'Продукты')"></a>
        <a href="/#about" @click="mobileOpen=false" class="text-sm text-slate-100/70 hover:text-slate-100" x-text="t('About Us', 'О нас')"></a>
        <a href="/#contact" @click="mobileOpen=false" class="text-sm text-slate-100/70 hover:text-slate-100" x-text="t('Contact', 'Контакты')"></a>
      </div>
    </nav>

    <!-- PAGE CONTENT -->
    <slot />

    <!-- FOOTER -->
    <footer class="py-10 bg-navy-dark border-t border-white/10">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-slate-100/25 text-xs text-center">© 2025 Onyx Corporation Ltd. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="#" class="text-slate-100/30 hover:text-slate-100/60 text-xs transition-colors">Privacy Policy</a>
          <a href="#" class="text-slate-100/30 hover:text-slate-100/60 text-xs transition-colors">Terms</a>
        </div>
      </div>
    </footer>

    <!-- Alpine.js -->
    <script>
      import Alpine from 'alpinejs'
      ;(window as any).Alpine = Alpine
      Alpine.start()
    </script>

  </body>
</html>
